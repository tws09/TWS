@startuml TWS_Use_Case_00_Index
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

' =======================
' CONSISTENT STYLING
' =======================
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #424242
    BorderThickness 1
    FontName "Arial"
    FontSize 10
}

skinparam arrow {
    Color #333333
    Thickness 1
}

skinparam note {
    BackgroundColor #FFFFFF
    BorderColor #888888
    BorderThickness 1
    FontName "Arial"
    FontSize 9
}

skinparam title {
    FontSize 14
    FontStyle bold
    FontName "Arial"
}

title TWS Multi-Tenant ERP Platform – Use Case Diagrams Index

left to right direction
scale 0.70

' =======================
' DIAGRAM STRUCTURE
' =======================
rectangle "Use Case Diagrams\nStructure" {
    
    rectangle "01: System Overview\n(High-Level View)" as D01 #E3F2FD
    rectangle "02: Authentication\n& Access" as D02 #FCE4EC
    rectangle "03: Platform\nAdministration" as D03 #E3F2FD
    rectangle "04: Education\nModule" as D04 #E3F2FD
    rectangle "05: Healthcare\nModule" as D05 #E3F2FD
    rectangle "06: Software House\nModule" as D06 #E3F2FD
    rectangle "07: Common\nFeatures" as D07 #E8F5E9
}

' =======================
' NOTES (Orthogonal Routing)
' =======================
note right of D01
  **Purpose**: Executive overview
  **Actors**: Supra Admin, Tenant Admin, User
  **Focus**: Core functions & modules
end note

note right of D02
  **Purpose**: Security & access
  **Actors**: All user types
  **Focus**: Login, signup, password recovery
end note

note right of D03
  **Purpose**: Admin functions
  **Actors**: Supra Admin, Tenant Admin
  **Focus**: Management & configuration
end note

note right of D04
  **Purpose**: Education ERP
  **Actors**: Principal, Teacher, Student
  **Focus**: Education-specific features
end note

note right of D05
  **Purpose**: Healthcare ERP
  **Actors**: Doctor, Patient, Receptionist
  **Focus**: Healthcare-specific features
end note

note right of D06
  **Purpose**: Software House ERP
  **Actors**: PM, Developer, Client
  **Focus**: Project management features
end note

note right of D07
  **Purpose**: Shared features
  **Actors**: All user types
  **Focus**: Dashboard, reports, messaging
end note

' =======================
' RELATIONSHIPS (Orthogonal Routing)
' =======================
D01 --> D02 : "Details"
D01 --> D03 : "Details"
D01 --> D04 : "Module"
D01 --> D05 : "Module"
D01 --> D06 : "Module"
D01 --> D07 : "Features"

@enduml
