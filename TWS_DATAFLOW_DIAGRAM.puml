@startuml TWS_Data_Flow_Level1
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

' =======================
' STYLING (DFD-ORIENTED, LOGICAL, TECH-AGNOSTIC)
' =======================
skinparam rectangle {
    BackgroundColor #E1F5FE
    BorderColor #01579B
    BorderThickness 1
    FontName "Arial"
    FontSize 10
    FontStyle bold
}

skinparam rectangle<<ExternalSystem>> {
    BackgroundColor #F5F5F5
    BorderColor #757575
    BorderThickness 1
    FontName "Arial"
    FontSize 9
    FontStyle normal
}

skinparam circle {
    BackgroundColor #FFF3E0
    BorderColor #E65100
    BorderThickness 2
    FontName "Arial"
    FontSize 10
}

skinparam database {
    BackgroundColor #F3E5F5
    BorderColor #4A148C
    BorderThickness 2
    FontName "Arial"
    FontSize 9
}

skinparam arrow {
    Color #333333
    Thickness 1
    FontSize 8
}

title TWS Multi-Tenant ERP Platform – Level 1 Data Flow Diagram (Logical)

left to right direction
scale 0.75

' =======================
' EXTERNAL ENTITIES
' Primary Actors (Human Users)
' =======================
rectangle "Supra Admin" as E_SupraAdmin
rectangle "Tenant Admin" as E_TenantAdmin
rectangle "Tenant Users\n(Managers, Employees,\nIndustry Roles)" as E_Users

' =======================
' EXTERNAL SYSTEMS (Supporting Infrastructure)
' =======================
rectangle "Email Service" as E_Email <<ExternalSystem>>
rectangle "File Storage System" as E_FileStore <<ExternalSystem>>

note right of E_Email
  **External Systems**
  Supporting infrastructure services
  (not human actors)
end note

' =======================
' PROCESSES (LOGICAL)
' =======================
circle "1.0\nAuthenticate Users" as P1
circle "2.0\nProvision Tenants" as P2
circle "3.0\nManage Users\n& Roles" as P3
circle "4.0\nManage Business Data\n(Industry & ERP)" as P4
circle "5.0\nMessaging &\nNotifications" as P5
circle "6.0\nReports & Files" as P6

' =======================
' DATA STORES (LOGICAL)
' =======================
database "D1\nAuthentication Data Store" as D1
database "D2\nTenant Configuration Store" as D2
database "D3\nUser & Role Store" as D3
database "D4\nOperational Data Store\n(Industry & ERP)" as D4
database "D5\nMessaging Store" as D5
database "D6\nAudit Log Store" as D6
database "D7\nFile Metadata Store" as D7

' =======================
' EXTERNAL → PROCESS FLOWS
' =======================
E_SupraAdmin --> P1 : Auth Request
E_SupraAdmin --> P2 : Tenant Setup Request
E_SupraAdmin --> P6 : Report / File Request

E_TenantAdmin --> P1 : Auth Request
E_TenantAdmin --> P3 : User / Role Request
E_TenantAdmin --> P4 : Module Data Request
E_TenantAdmin --> P6 : Report / File Request

E_Users --> P1 : Auth Request
E_Users --> P4 : Data Submission / Query
E_Users --> P5 : Message / Prefs
E_Users --> P6 : Report / File Request

E_Email --> P5 : Delivery Status
E_FileStore --> P6 : File Data / Status

' =======================
' PROCESS → EXTERNAL FLOWS
' =======================
P1 --> E_SupraAdmin : Auth Status
P1 --> E_TenantAdmin : Auth Status
P1 --> E_Users : Auth Status

P2 --> E_SupraAdmin : Tenant Provisioning Status

P4 --> E_Users : Data Response
P5 --> E_Users : Notifications / Alerts
P6 --> E_SupraAdmin : Reports / Files
P6 --> E_TenantAdmin : Reports / Files
P6 --> E_Users : Reports / Files

P5 --> E_Email : Notification Request
P6 --> E_FileStore : File Metadata / Access

' =======================
' PROCESS → DATA STORE FLOWS (DASHED FOR DATA ACCESS)
' =======================
P1 ..> D1 : R/W Auth Data
P1 ..> D6 : W Auth Audit

P2 ..> D2 : R/W Tenant Config
P2 ..> D3 : W Initialize Default Roles
P2 ..> D4 : W Initialize Tenant Data
P2 ..> D6 : W Provisioning Audit

P3 ..> D3 : R/W User & Roles
P3 ..> D6 : W User Mgmt Audit

P4 ..> D4 : R/W Operational Data
P4 ..> D3 : R Access Control
P4 ..> D6 : W Operations Audit

P5 ..> D5 : R/W Messages
P5 ..> D3 : R Recipient Access
P5 ..> D6 : W Messaging Audit

P6 ..> D4 : R Data for Reports
P6 ..> D7 : R/W File Metadata
P6 ..> D6 : W Reporting Audit

@enduml
