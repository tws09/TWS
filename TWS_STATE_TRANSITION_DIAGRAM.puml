@startuml TWS_State_Transitions
!theme plain
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 15

skinparam state {
  FontName "Arial"
  FontSize 12
  BorderColor #333333
  BackgroundColor #F7F7F7
}

skinparam arrow {
  Color #333333
  Thickness 1
  FontSize 10
}

title TWS Multi-Tenant ERP Platform – State Transition Diagrams

top to bottom direction
scale 0.75

' =======================
' TENANT STATE TRANSITIONS
' =======================
[*] --> Tenant_Pending : Tenant Creation Request
state "Tenant\nPending Setup" as Tenant_Pending
state "Tenant\nActive" as Tenant_Active
state "Tenant\nSuspended" as Tenant_Suspended
state "Tenant\nCancelled" as Tenant_Cancelled

Tenant_Pending --> Tenant_Active : Setup Completed
Tenant_Pending --> Tenant_Cancelled : Cancelled During Setup
Tenant_Active --> Tenant_Suspended : Compliance Issue\nBilling Issue
Tenant_Suspended --> Tenant_Active : Issue Resolved
Tenant_Active --> Tenant_Cancelled : Terminated
Tenant_Suspended --> Tenant_Cancelled : Terminated

' =======================
' USER STATE TRANSITIONS
' =======================
[*] --> User_Pending : User Creation
state "User\nPending Activation" as User_Pending
state "User\nInactive" as User_Inactive
state "User\nActive" as User_Active
state "User\nSuspended" as User_Suspended
state "User\nDeactivated" as User_Deactivated

User_Pending --> User_Active : Provisioned / Activated
User_Active --> User_Suspended : Policy Violation
User_Suspended --> User_Active : Reinstated
User_Active --> User_Deactivated : Deactivated
User_Pending --> User_Deactivated : Activation Failed
User_Suspended --> User_Deactivated : Deactivation After Violation
User_Inactive --> User_Active : Activated

' =======================
' SUBSCRIPTION STATE TRANSITIONS
' =======================
[*] --> Subscription_Trial : Tenant Created
state "Subscription\nTrial" as Subscription_Trial
state "Subscription\nActive" as Subscription_Active
state "Subscription\nSuspended" as Subscription_Suspended
state "Subscription\nExpired" as Subscription_Expired
state "Subscription\nCancelled" as Subscription_Cancelled

Subscription_Trial --> Subscription_Active : Payment Confirmed
Subscription_Trial --> Subscription_Expired : Trial Period Ended
Subscription_Trial --> Subscription_Cancelled : Cancelled
Subscription_Active --> Subscription_Suspended : Non-Payment
Subscription_Active --> Subscription_Cancelled : Cancelled
Subscription_Active --> Subscription_Expired : Subscription Ended
Subscription_Suspended --> Subscription_Active : Payment Received
Subscription_Suspended --> Subscription_Cancelled : Cancelled

' =======================
' PROJECT STATE TRANSITIONS
' =======================
[*] --> Project_Planning : Project Created
state "Project\nPlanning" as Project_Planning
state "Project\nActive" as Project_Active
state "Project\nOn Hold" as Project_Hold
state "Project\nCompleted" as Project_Done
state "Project\nCancelled" as Project_Cancel
state "Project\nArchived" as Project_Archived

Project_Planning --> Project_Active : Kicked Off
Project_Planning --> Project_Cancel : Cancelled
Project_Active --> Project_Hold : Paused
Project_Hold --> Project_Active : Resumed
Project_Active --> Project_Done : Delivered
Project_Active --> Project_Cancel : Cancelled
Project_Done --> Project_Archived : Archived

@enduml

