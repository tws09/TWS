@startuml TWS_Use_Case_02_Authentication
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

' =======================
' ACTOR STYLES
' =======================
skinparam actor {
    FontName "Arial"
    FontSize 10
    BorderThickness 1
}

skinparam actor<<Admin>> {
    BackgroundColor #E1F5FE
    BorderColor #01579B
}

skinparam actor<<Internal>> {
    BackgroundColor #E0F2F1
    BorderColor #00695C
}

skinparam actor<<External>> {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

' =======================
' USE CASE STYLES
' =======================

skinparam usecase<<Core>> {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    BorderThickness 1
}

skinparam usecase<<Support>> {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    BorderThickness 1
}

skinparam usecase<<Security>> {
    BackgroundColor #FCE4EC
    BorderColor #AD1457
    BorderThickness 1
}

' =======================
' SYSTEM BOUNDARY
' =======================
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #424242
    BorderThickness 1
}

title TWS Multi-Tenant ERP Platform – Authentication & Access Use Case Diagram

left to right direction
scale 0.70

' =======================
' ACTORS (All on Left Side)
' =======================
actor "Supra Admin" as SupraAdmin <<Admin>>
actor "Tenant Admin" as TenantAdmin <<Admin>>
actor "Pre-Tenant User" as PreTenantUser <<External>>
actor "User" as User <<Internal>>

' =======================
' SYSTEM BOUNDARY
' =======================
rectangle "TWS MULTI-TENANT ERP SYSTEM" {

    package "Authentication Module" {
        usecase "Sign Up Tenant" as UC02 <<Core>>
    }

    package "Common ERP Features" {
        usecase "Manage User Profile" as UC14 <<Support>>

        usecase "Authenticate User" as UC_Auth <<Security>>
        usecase "Recover Password" as UC_Password <<Security>>
    }
}

' =======================
' ACTOR ASSOCIATIONS (Orthogonal Routing)
' All actors connect to Authenticate User
' =======================
SupraAdmin --> UC_Auth
SupraAdmin --> UC14

TenantAdmin --> UC_Auth
TenantAdmin --> UC14

PreTenantUser --> UC_Auth
PreTenantUser --> UC02

User --> UC_Auth
User --> UC14
User --> UC_Password

' =======================
' USE CASE RELATIONSHIPS
' All use cases <<include>> Authenticate User
' =======================
UC02 ..> UC_Auth : <<include>>
UC14 ..> UC_Auth : <<include>>

UC_Password ..> UC_Auth : <<extend>>

@enduml
