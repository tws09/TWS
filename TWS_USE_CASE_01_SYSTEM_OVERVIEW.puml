@startuml TWS_Use_Case_01_System_Overview
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

' =======================
' ACTOR STYLES
' =======================
skinparam actor {
    FontName "Arial"
    FontSize 10
    BorderThickness 1
}

skinparam actor<<Admin>> {
    BackgroundColor #E1F5FE
    BorderColor #01579B
}

skinparam actor<<Internal>> {
    BackgroundColor #E0F2F1
    BorderColor #00695C
}

skinparam actor<<External>> {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

' =======================
' USE CASE STYLES
' =======================

skinparam usecase<<Core>> {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    BorderThickness 1
}

skinparam usecase<<Support>> {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    BorderThickness 1
}

skinparam usecase<<Security>> {
    BackgroundColor #FCE4EC
    BorderColor #AD1457
    BorderThickness 1
}

' =======================
' SYSTEM BOUNDARY
' =======================
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #424242
    BorderThickness 1
}

title TWS Multi-Tenant ERP Platform – System Overview Use Case Diagram

left to right direction
scale 0.70

' =======================
' ACTORS (All on Left Side)
' =======================
actor "Supra Admin" as SupraAdmin <<Admin>>
actor "Tenant Admin" as TenantAdmin <<Admin>>
actor "User" as User <<Internal>>

' =======================
' SYSTEM BOUNDARY
' =======================
rectangle "TWS MULTI-TENANT ERP SYSTEM" {

    package "Core Functions Module" {
        usecase "Tenant Signup" as UC02 <<Core>>
        usecase "Tenant Management" as UC03 <<Core>>
        usecase "User Management" as UC04 <<Core>>
        usecase "Role Management" as UC05 <<Core>>
    }

    package "Industry Modules" {
        usecase "Education ERP" as UC07 <<Core>>
        usecase "Healthcare ERP" as UC08 <<Core>>
        usecase "Software House ERP" as UC09 <<Core>>
    }

    package "Common ERP Features" {
        usecase "View Dashboard\n& Analytics" as UC10 <<Support>>
        usecase "Generate & Export\nReports" as UC11 <<Support>>
        usecase "Send Messages &\nNotifications" as UC12 <<Support>>

        usecase "Authenticate User" as UC_Auth <<Security>>
        usecase "Recover Password" as UC_Password <<Security>>
    }
}

' =======================
' ACTOR ASSOCIATIONS (Orthogonal Routing)
' All actors connect to Authenticate User
' =======================
SupraAdmin --> UC_Auth
SupraAdmin --> UC03
SupraAdmin --> UC10
SupraAdmin --> UC11

TenantAdmin --> UC_Auth
TenantAdmin --> UC02
TenantAdmin --> UC04
TenantAdmin --> UC05
TenantAdmin --> UC07
TenantAdmin --> UC08
TenantAdmin --> UC09
TenantAdmin --> UC10
TenantAdmin --> UC11
TenantAdmin --> UC12

User --> UC_Auth
User --> UC10
User --> UC12
User --> UC_Password

' =======================
' USE CASE RELATIONSHIPS
' All use cases <<include>> Authenticate User
' =======================
UC02 ..> UC_Auth : <<include>>
UC03 ..> UC_Auth : <<include>>
UC04 ..> UC_Auth : <<include>>
UC05 ..> UC_Auth : <<include>>

UC07 ..> UC_Auth : <<include>>
UC08 ..> UC_Auth : <<include>>
UC09 ..> UC_Auth : <<include>>

UC10 ..> UC_Auth : <<include>>
UC11 ..> UC_Auth : <<include>>
UC12 ..> UC_Auth : <<include>>

UC_Password ..> UC_Auth : <<extend>>

' =======================
' NOTES
' =======================
note right of SupraAdmin
  Platform-level
  administration
end note

note right of TenantAdmin
  Tenant-level
  administration
end note

note right of User
  General users
  (Employees, Managers,
  Industry-specific roles)
end note

@enduml
