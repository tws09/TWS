@startuml TWS_Use_Case_05_Healthcare
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

' =======================
' ACTOR STYLES
' =======================
skinparam actor {
    FontName "Arial"
    FontSize 10
    BorderThickness 1
}

skinparam actor<<Admin>> {
    BackgroundColor #E1F5FE
    BorderColor #01579B
}

skinparam actor<<Internal>> {
    BackgroundColor #E0F2F1
    BorderColor #00695C
}

skinparam actor<<External>> {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

' =======================
' USE CASE STYLES
' =======================

skinparam usecase<<Core>> {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    BorderThickness 1
}

skinparam usecase<<Support>> {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    BorderThickness 1
}

skinparam usecase<<Security>> {
    BackgroundColor #FCE4EC
    BorderColor #AD1457
    BorderThickness 1
}

' =======================
' SYSTEM BOUNDARY
' =======================
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #424242
    BorderThickness 1
}

title TWS Multi-Tenant ERP Platform – Healthcare Module Use Case Diagram

left to right direction
scale 0.70

' =======================
' ACTORS (All on Left Side)
' =======================
actor "Tenant Admin" as TenantAdmin <<Admin>>
actor "Doctor" as Doctor <<Internal>>
actor "Receptionist" as Receptionist <<Internal>>
actor "Patient" as Patient <<External>>

' =======================
' SYSTEM BOUNDARY
' =======================
rectangle "TWS MULTI-TENANT ERP SYSTEM" {

    package "Healthcare Module" {
        usecase "Patient\nManagement" as UC_Patient <<Core>>
        usecase "Medical\nRecords" as UC_Records <<Core>>
        usecase "Prescription\nManagement" as UC_Prescription <<Core>>
        usecase "Billing &\nInvoicing" as UC_Billing <<Core>>
        usecase "Appointment\nManagement" as UC_Appointment <<Core>>
        usecase "Department\nManagement" as UC_Dept <<Core>>
    }

    package "Common ERP Features" {
        usecase "View Dashboard\n& Analytics" as UC_Dashboard <<Support>>
        usecase "Generate & Export\nReports" as UC_Report <<Support>>
        usecase "Send Messages &\nNotifications" as UC_Comm <<Support>>
        usecase "Manage User Profile" as UC_Profile <<Support>>

        usecase "Authenticate User" as UC_Auth <<Security>>
        usecase "Recover Password" as UC_Password <<Security>>
    }
}

' =======================
' ACTOR ASSOCIATIONS (Orthogonal Routing)
' =======================
TenantAdmin --> UC_Auth
TenantAdmin --> UC_Patient
TenantAdmin --> UC_Records
TenantAdmin --> UC_Dept
TenantAdmin --> UC_Dashboard
TenantAdmin --> UC_Report
TenantAdmin --> UC_Profile
TenantAdmin --> UC_Comm

Doctor --> UC_Auth
Doctor --> UC_Records
Doctor --> UC_Prescription
Doctor --> UC_Appointment
Doctor --> UC_Dashboard
Doctor --> UC_Report
Doctor --> UC_Comm
Doctor --> UC_Profile

Receptionist --> UC_Auth
Receptionist --> UC_Patient
Receptionist --> UC_Appointment
Receptionist --> UC_Comm
Receptionist --> UC_Profile

Patient --> UC_Auth
Patient --> UC_Records
Patient --> UC_Prescription
Patient --> UC_Billing
Patient --> UC_Appointment
Patient --> UC_Dashboard
Patient --> UC_Comm
Patient --> UC_Profile
Patient --> UC_Password

' =======================
' USE CASE RELATIONSHIPS
' All use cases <<include>> Authenticate User
' =======================
UC_Patient ..> UC_Auth : <<include>>
UC_Records ..> UC_Auth : <<include>>
UC_Prescription ..> UC_Auth : <<include>>
UC_Billing ..> UC_Auth : <<include>>
UC_Appointment ..> UC_Auth : <<include>>
UC_Dept ..> UC_Auth : <<include>>

UC_Dashboard ..> UC_Auth : <<include>>
UC_Report ..> UC_Auth : <<include>>
UC_Comm ..> UC_Auth : <<include>>
UC_Profile ..> UC_Auth : <<include>>

UC_Password ..> UC_Auth : <<extend>>

@enduml
