flowchart TB
    subgraph Frontend["🖥️ FRONTEND LAYER"]
        direction TB
        A[👤 User] -->|Clicks Create Project| B[CreateProjectModal Component]
        B -->|1. e.preventDefault| C{Form Validation}
        C -->|Invalid| D[Display Validation Errors]
        C -->|Valid| E[Sanitize Data<br/>Convert budget to float<br/>Convert hours to int]
        E --> F[tenantProjectApiService.createProject]
        F --> G[getTenantToken]
        G -->|No Token| H[Show Please Log In Error]
        G -->|Has Token| I[Build HTTP Request<br/>POST /api/tenant/:slug/organization/projects<br/>Headers: Authorization Bearer token]
    end

    subgraph Network["🌐 NETWORK LAYER"]
        direction TB
        I --> J{Development Mode?}
        J -->|Yes| K[Proxy: Forward to localhost:5000]
        J -->|No| L[Direct Request to Server]
        K --> M[Express Server]
        L --> M
    end

    subgraph BackendAuth["🔐 BACKEND AUTHENTICATION"]
        direction TB
        M -->|Parse Route| N[authenticateToken Middleware]
        N -->|Extract Token| O{Token Valid?}
        O -->|No Token| P[401 Unauthorized]
        O -->|Expired| Q[401 Token Expired]
        O -->|Valid| R[Decode Token<br/>Set req.user]
        Q -->|Auto Retry| I
        P -->|Error| F
    end

    subgraph BackendTenant["🏢 BACKEND TENANT VERIFICATION"]
        direction TB
        R --> S[verifyTenantOrgAccess Middleware]
        S -->|Extract tenantSlug| T[Find Tenant by Slug]
        T -->|Not Found| U[Try findById]
        U -->|Still Not Found| V[Try findOne by tenantId]
        V -->|Not Found| W[404 Tenant Not Found]
        T -->|Found| X{User Has Access?}
        X -->|No| Y[403 Access Denied]
        X -->|Yes| Z[Set req.tenant<br/>Set req.user]
        W -->|Error| F
        Y -->|Error| F
    end

    subgraph BackendContext["📋 BACKEND CONTEXT SETUP"]
        direction TB
        Z --> AA[setTenantContext Middleware]
        AA --> BB[Set Tenant Database Context]
        BB --> CC[ensureTenantContext Middleware]
        CC -->|Check req.tenant| DD{Tenant Set?}
        DD -->|No| EE[500 Tenant Not Available]
        DD -->|Yes| FF[buildTenantContext]
        FF --> GG[Set req.tenantContext.orgId]
        EE -->|Error| F
    end

    subgraph BackendController["⚙️ BACKEND CONTROLLER"]
        direction TB
        GG --> HH[Projects Router<br/>POST /projects]
        HH --> II[ProjectsController.createProject]
        II --> JJ[getOrgId Helper]
        JJ -->|Try 1| KK{req.tenantContext.orgId?}
        KK -->|No| LL[Try 2: req.tenant.orgId]
        LL -->|No| MM[Try 3: req.tenant.organizationId]
        MM -->|No| NN[Try 4: req.user.orgId]
        NN -->|No| OO[Try 5: Find Organization by slug]
        OO -->|Found| PP[orgId = organization._id]
        OO -->|Not Found| QQ[orgId = null]
        KK -->|Found| PP
        LL -->|Found| PP
        MM -->|Found| PP
        NN -->|Found| PP
        QQ -->|Error| RR[500 Organization Context Not Available]
        PP --> SS[Extract Data from req.body]
        SS --> TT{Validate Required Fields}
        TT -->|Invalid| UU[400 Project Name Required]
        TT -->|Valid| VV[Generate Slug from Name]
        VV --> WW[Check Duplicate Project]
        WW -->|Exists| XX[400 Project Already Exists]
        WW -->|Unique| YY[Create New Project Object]
        RR -->|Error| F
        UU -->|Error| F
        XX -->|Error| F
    end

    subgraph Database["💾 DATABASE OPERATIONS"]
        direction TB
        YY --> ZZ[(MongoDB)]
        ZZ -->|Save Project| AAA[Insert into Projects Collection]
        AAA -->|Success| BBB[Populate clientId Relation]
        BBB --> CCC[Project Document with Relations]
    end

    subgraph Response["📤 RESPONSE FLOW"]
        direction TB
        CCC --> DDD[201 Created Response<br/>success: true<br/>data: project<br/>message: Project created]
        DDD --> EEE[HTTP Response with JSON]
        EEE --> FFF[ApiService Receives Response]
        FFF --> GGG[Parse JSON Response]
        GGG --> HHH[Return Project Data]
    end

    subgraph UIUpdate["✨ UI UPDATES"]
        direction TB
        HHH --> III[CreateProjectModal Receives Data]
        III --> JJJ[handleSuccess Notification]
        JJJ --> KKK[Call onProjectCreated Callback]
        KKK --> LLL[onClose Modal]
        LLL --> MMM[resetForm Clear Form]
        MMM --> NNN[Set isLoading = false]
        NNN --> OOO[Trigger Parent Refresh]
        OOO --> PPP[ProjectsOverview Refreshes List]
        PPP -->|Success| QQQ[✅ User Sees Success Message<br/>Modal Closes<br/>Form Resets<br/>Project List Updates]
    end

    subgraph ErrorHandling["⚠️ ERROR HANDLING PATHS"]
        direction TB
        D --> RRR[End with Error]
        H --> RRR
        P --> RRR
        Q -->|After Retry Fails| RRR
        W --> RRR
        Y --> RRR
        EE --> RRR
        RR --> RRR
        UU --> RRR
        XX --> RRR
    end

    Frontend --> Network
    Network --> BackendAuth
    BackendAuth --> BackendTenant
    BackendTenant --> BackendContext
    BackendContext --> BackendController
    BackendController --> Database
    Database --> Response
    Response --> UIUpdate
    
    ErrorHandling -.->|All Errors| RRR

    style A fill:#e1f5ff
    style B fill:#fff4e6
    style F fill:#fff4e6
    style M fill:#f3e5f5
    style N fill:#ffebee
    style S fill:#ffebee
    style AA fill:#ffebee
    style CC fill:#ffebee
    style II fill:#e8f5e9
    style ZZ fill:#fff9c4
    style DDD fill:#c8e6c9
    style QQQ fill:#c8e6c9
    style RRR fill:#ffcdd2
