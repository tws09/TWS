{
  "name": "tws-backend",
  "version": "1.0.0",
  "description": "TWS Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "echo \"No build step for Node backend\"",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate:up": "node src/migrations/migrate.js up",
    "migrate:down": "node src/migrations/migrate.js down",
    "migrate:status": "node src/migrations/migrate.js status",
    "seed:supraadmin": "node src/scripts/seedSupraAdmin.js",
    "seed:education": "node src/scripts/seedEducationData.js",
    "seed:employee-sufyan": "node scripts/seed-employee-sufyan.js",
    "worker:file-processor": "node src/workers/fileProcessor.js",
    "worker:notifications": "node src/scripts/startNotificationWorkers.js",
    "worker:retention": "node src/scripts/startRetentionWorker.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "setup:keys": "node scripts/generate-encryption-keys.js",
    "setup:verify": "node scripts/verify-setup.js",
    "setup:indexes": "node src/scripts/createEducationIndexes.js",
    "setup:test": "node src/scripts/testEducationImplementation.js",
    "setup:all": "npm run setup:verify && npm run setup:indexes && npm run setup:test",
    "nucleus:migrate": "node src/scripts/nucleusMigration.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.943.0",
    "@aws-sdk/s3-request-presigner": "^3.943.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^7.120.4",
    "@socket.io/redis-adapter": "^8.2.1",
    "aws-sdk": "^2.1692.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.18.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.5.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^161.0.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.2.0",
    "ioredis": "^5.8.0",
    "isomorphic-dompurify": "^2.34.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers": "^0.7.15",
    "moment-timezone": "^0.6.0",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.15.0",
    "prom-client": "^15.0.0",
    "sharp": "^0.32.6",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.22.15",
    "aws-sdk-mock": "^5.8.0",
    "eslint": "^8.48.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^8.16.1",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/src/tests/setup.js"
    ],
    "globalTeardown": "<rootDir>/src/tests/teardown.js",
    "forceExit": true,
    "detectOpenHandles": false,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/tests/**",
      "!src/migrations/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|@sendgrid)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "keywords": [
    "express",
    "mongodb",
    "file-sharing",
    "messaging"
  ],
  "author": "TWS Team",
  "license": "MIT"
}
