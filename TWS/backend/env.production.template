# Production Environment Configuration
# This file is for reference only - actual values should be set in your deployment environment

# Required Variables
NODE_ENV=production
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/tws-production?retryWrites=true&w=majority
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
ENCRYPTION_MASTER_KEY=your-encryption-key-here

# Optional Variables
PORT=4000
BASE_URL=https://your-app.domain.com
SOCKET_CORS_ORIGIN=https://your-app.domain.com
LOG_LEVEL=info

# Feature Flags
ENCRYPTION_ENABLED=true
AUDIT_LOGGING_ENABLED=true
RBAC_ENABLED=true
COMPLIANCE_MODE=disabled
GDPR_COMPLIANCE=false
SOX_COMPLIANCE=false
HIPAA_COMPLIANCE=false
BACKUP_ENABLED=false
MONITORING_ENABLED=true
METRICS_ENABLED=true
