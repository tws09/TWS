{
  "name": "wolfstack-frontend",
  "version": "1.0.0",
  "description": "Frontend React application for The Wolf Stack Management Portal",
  "private": true,
  "dependencies": {
    "@blocknote/core": "^0.16.0",
    "@blocknote/mantine": "^0.16.0",
    "@blocknote/react": "^0.16.0",
    "@mantine/core": "^7.0.0",
    "@mantine/hooks": "^7.0.0",
    "@ant-design/icons": "^6.1.0",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@use-gesture/react": "^10.3.1",
    "antd": "^5.27.6",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.0",
    "chart.js": "^4.5.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^12.23.22",
    "html-docx-js": "^0.3.1",
    "html2pdf.js": "^0.10.2",
    "lucide-react": "^0.292.0",
    "postcss": "^8.4.31",
    "prosemirror-view": "1.33.11",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-chartjs-2": "^5.3.0",
    "react-datepicker": "^4.21.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.18.0",
    "react-scripts": "^5.0.1",
    "react-spring": "^10.0.3",
    "react-window": "^1.8.8",
    "react-window-infinite-loader": "^1.0.9",
    "recharts": "^2.8.0",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^3.3.5"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",
    "jest": "^27.5.1",
    "jest-axe": "^7.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "prop-types": "^15.8.1",
    "web-vitals": "^2.1.4",
    "webpack": "^5.102.0"
  },
  "scripts": {
    "start": "craco start",
    "dev": "craco start",
    "build": "craco build",
    "test": "craco test",
    "test:watch": "craco test --watch",
    "test:coverage": "craco test --coverage",
    "test:a11y": "craco test --testPathPattern=accessibility",
    "eject": "react-scripts eject",
    "test:all": "npm run test"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "no-unused-vars": "off",
      "react-hooks/exhaustive-deps": "off",
      "no-dupe-keys": "off",
      "no-dupe-class-members": "off",
      "no-mixed-operators": "off",
      "import/no-anonymous-default-export": "off",
      "no-useless-escape": "off",
      "jsx-a11y/anchor-is-valid": "off",
      "jsx-a11y/role-supports-aria-props": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:5000",
  "overrides": {
    "prosemirror-view": "1.33.11"
  }
}
