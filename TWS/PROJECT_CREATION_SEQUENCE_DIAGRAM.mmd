sequenceDiagram
    participant User
    participant CreateProjectModal as CreateProjectModal Frontend
    participant Validation as Form Validation
    participant ApiService as TenantProjectApiService
    participant TokenManager as Token Manager
    participant HTTP as HTTP Request
    participant Proxy as setupProxy
    participant Backend as Express Server
    participant AuthMiddleware as authenticateToken
    participant TenantMiddleware as verifyTenantOrgAccess
    participant TenantContext as setTenantContext
    participant EnsureContext as ensureTenantContext
    participant ProjectsRoute as Projects Router
    participant Controller as ProjectsController
    participant GetOrgId as getOrgId Helper
    participant Database as MongoDB
    participant Response as HTTP Response

    User->>CreateProjectModal: Click Create Project Button
    CreateProjectModal->>CreateProjectModal: Set isLoading true
    
    CreateProjectModal->>CreateProjectModal: e.preventDefault()
    CreateProjectModal->>Validation: validateForm(formData)
    Validation->>Validation: Check required fields
    Validation->>Validation: Validate data types
    Validation-->>CreateProjectModal: Validation result
    
    alt Validation Fails
        CreateProjectModal->>CreateProjectModal: Display validation errors
        CreateProjectModal->>CreateProjectModal: Set isLoading false
        CreateProjectModal-->>User: Show error messages
    end
    
    CreateProjectModal->>CreateProjectModal: sanitizeProjectData(formData)
    Note over CreateProjectModal: Convert budget to float and estimatedHours to int
    
    CreateProjectModal->>ApiService: createProject(tenantSlug, sanitizedData)
    
    ApiService->>TokenManager: getTenantToken()
    TokenManager->>TokenManager: Check localStorage for token
    alt No Token Found
        TokenManager-->>ApiService: Throw Error
        ApiService-->>CreateProjectModal: Error
        CreateProjectModal-->>User: Show Please log in message
    end
    
    ApiService->>ApiService: Build endpoint URL
    ApiService->>ApiService: Prepare request options
    ApiService->>HTTP: fetch(url, options)
    HTTP->>HTTP: Add headers with token
    
    alt Development Mode
        HTTP->>Proxy: Forward to localhost:5000
        Proxy->>Backend: Forward request
    else Production Mode
        HTTP->>Backend: Direct request
    end
    
    Backend->>Backend: Parse route
    Backend->>AuthMiddleware: authenticateToken(req, res, next)
    AuthMiddleware->>AuthMiddleware: Extract token
    alt No Token
        AuthMiddleware-->>Response: 401 Unauthorized
        Response-->>HTTP: 401 Error
        HTTP-->>ApiService: 401 Response
        ApiService->>ApiService: Check if token expired
        alt Token Expired
            ApiService->>ApiService: refreshTenantToken()
            ApiService->>ApiService: Retry request
        else Other 401 Error
            ApiService-->>CreateProjectModal: Authentication Error
        end
    end
    
    AuthMiddleware->>AuthMiddleware: Verify JWT token
    AuthMiddleware->>AuthMiddleware: Check token blacklist
    AuthMiddleware->>AuthMiddleware: Decode token and set req.user
    AuthMiddleware->>TenantMiddleware: next()
    
    TenantMiddleware->>TenantMiddleware: Extract tenantSlug
    TenantMiddleware->>TenantMiddleware: Extract token
    TenantMiddleware->>TenantMiddleware: Verify token
    TenantMiddleware->>Database: Find tenant by slug
    
    alt Tenant Not Found
        TenantMiddleware->>Database: Try findById
        alt Still Not Found
            TenantMiddleware->>Database: Try findOne by tenantId
            alt Still Not Found
                TenantMiddleware-->>Response: 404 Not Found
                Response-->>HTTP: 404 Error
                HTTP-->>ApiService: 404 Response
                ApiService-->>CreateProjectModal: Error
            end
        end
    end
    
    TenantMiddleware->>TenantMiddleware: Check user access
    alt Access Denied
        TenantMiddleware-->>Response: 403 Forbidden
        Response-->>HTTP: 403 Error
        HTTP-->>ApiService: 403 Response
        ApiService-->>CreateProjectModal: Error
    end
    
    TenantMiddleware->>TenantMiddleware: Set req.tenant and req.user
    TenantMiddleware->>TenantContext: next()
    TenantContext->>TenantContext: Set tenant database context
    TenantContext->>EnsureContext: next()
    
    EnsureContext->>EnsureContext: Check if req.tenant exists
    alt Tenant Not Set
        EnsureContext-->>Response: 500 Internal Server Error
        Response-->>HTTP: 500 Error
    end
    
    EnsureContext->>EnsureContext: Build tenantContext
    EnsureContext->>EnsureContext: Set req.tenantContext.orgId
    EnsureContext->>ProjectsRoute: next()
    
    ProjectsRoute->>ProjectsRoute: Match POST /projects
    ProjectsRoute->>Controller: createProject(req, res)
    
    Controller->>GetOrgId: await getOrgId(req)
    GetOrgId->>GetOrgId: Try req.tenantContext.orgId
    alt Not Found
        GetOrgId->>GetOrgId: Try req.tenant.orgId
        alt Not Found
            GetOrgId->>GetOrgId: Try req.tenant.organizationId
            alt Not Found
                GetOrgId->>GetOrgId: Try req.user.orgId
                alt Not Found
                    GetOrgId->>Database: Find Organization by slug
                    alt Found
                        GetOrgId-->>Controller: orgId = organization._id
                    else Not Found
                        GetOrgId-->>Controller: null
                    end
                end
            end
        end
    end
    
    alt orgId is null
        Controller-->>Response: 500 Internal Server Error
        Response-->>HTTP: 500 Error
        HTTP-->>ApiService: 500 Response
        ApiService-->>CreateProjectModal: Error
    end
    
    Controller->>Controller: Extract data from req.body
    Controller->>Controller: Validate required fields
    
    alt Validation Fails
        Controller-->>Response: 400 Bad Request
        Response-->>HTTP: 400 Error
        HTTP-->>ApiService: 400 Response
        ApiService-->>CreateProjectModal: Validation Error
    end
    
    Controller->>Controller: Generate slug from name
    Controller->>Database: Project.findOne check duplicate
    alt Project Exists
        Database-->>Controller: existingProject found
        Controller-->>Response: 400 Bad Request
        Response-->>HTTP: 400 Error
        HTTP-->>ApiService: 400 Response
        ApiService-->>CreateProjectModal: Error
    end
    
    Controller->>Controller: new Project with all fields
    Controller->>Database: project.save()
    Database->>Database: Insert document
    Database-->>Controller: Saved project document
    
    Controller->>Database: project.populate clientId
    Database-->>Controller: Project with populated clientId
    
    Controller->>Controller: Log success
    Controller-->>Response: 201 Created with project data
    Response->>HTTP: 201 Response with JSON
    HTTP-->>ApiService: 201 Response
    
    ApiService->>ApiService: Parse JSON response
    ApiService->>ApiService: Return data
    ApiService-->>CreateProjectModal: Project data
    
    CreateProjectModal->>CreateProjectModal: handleSuccess
    CreateProjectModal->>CreateProjectModal: Call onProjectCreated callback
    CreateProjectModal->>CreateProjectModal: onClose
    CreateProjectModal->>CreateProjectModal: resetForm
    CreateProjectModal->>CreateProjectModal: Set isLoading false
    
    CreateProjectModal->>CreateProjectModal: Trigger parent refresh
    CreateProjectModal-->>User: Show success notification
    CreateProjectModal-->>User: Modal closes
    CreateProjectModal-->>User: Form resets
    CreateProjectModal-->>User: Project list refreshes
