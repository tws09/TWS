        {
          "name": "Health Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/metrics/health",
              "host": ["{{apiBase}}"],
              "path": ["metrics", "health"]
            }
          },
          "response": []
