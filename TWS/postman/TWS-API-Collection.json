{
  "info": {
    "name": "TWS Messaging System API",
    "description": "Complete API collection for TWS messaging system with authentication, messaging, analytics, and compliance features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "apiBase",
      "value": "{{baseUrl}}/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "chatId",
      "value": "",
      "type": "string"
    },
    {
      "key": "messageId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/register",
              "host": ["{{apiBase}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', response.token);",
                  "    pm.collectionVariables.set('userId', response.user._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/login",
              "host": ["{{apiBase}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/auth/profile",
              "host": ["{{apiBase}}"],
              "path": ["auth", "profile"]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/auth/refresh",
              "host": ["{{apiBase}}"],
              "path": ["auth", "refresh"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Messaging",
      "item": [
        {
          "name": "Create Chat",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('chatId', response.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Chat\",\n  \"type\": \"group\",\n  \"members\": [\"{{userId}}\"]\n}"
            },
            "url": {
              "raw": "{{apiBase}}/messaging/chats",
              "host": ["{{apiBase}}"],
              "path": ["messaging", "chats"]
            }
          },
          "response": []
        },
        {
          "name": "Get Chats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/messaging/chats",
              "host": ["{{apiBase}}"],
              "path": ["messaging", "chats"]
            }
          },
          "response": []
        },
        {
          "name": "Get Chat by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/messaging/chats/{{chatId}}",
              "host": ["{{apiBase}}"],
              "path": ["messaging", "chats", "{{chatId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Send Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('messageId', response.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello, this is a test message!\",\n  \"type\": \"text\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/messaging/chats/{{chatId}}/messages",
              "host": ["{{apiBase}}"],
              "path": ["messaging", "chats", "{{chatId}}", "messages"]
            }
          },
          "response": []
        },
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/messaging/chats/{{chatId}}/messages?limit=20",
              "host": ["{{apiBase}}"],
              "path": ["messaging", "chats", "{{chatId}}", "messages"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Edit Message",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This message has been edited!\"\n}"
            },
            "url": {
              "raw": "{{apiBase}}/messaging/messages/{{messageId}}",
              "host": ["{{apiBase}}"],
              "path": ["messaging", "messages", "{{messageId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Message",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/messaging/messages/{{messageId}}",
              "host": ["{{apiBase}}"],
              "path": ["messaging", "messages", "{{messageId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "File Management",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "test-file.txt"
                },
                {
                  "key": "chatId",
                  "value": "{{chatId}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{apiBase}}/files/upload",
              "host": ["{{apiBase}}"],
              "path": ["files", "upload"]
            }
          },
          "response": []
        },
        {
          "name": "Get Chat Files",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/files/chat/{{chatId}}",
              "host": ["{{apiBase}}"],
              "path": ["files", "chat", "{{chatId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/files/{{fileId}}/download",
              "host": ["{{apiBase}}"],
              "path": ["files", "{{fileId}}", "download"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard Overview",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/analytics/dashboard",
              "host": ["{{apiBase}}"],
              "path": ["analytics", "dashboard"]
            }
          },
          "response": []
        },
        {
          "name": "Active Chats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/analytics/active-chats?timeframe=24h&limit=20",
              "host": ["{{apiBase}}"],
              "path": ["analytics", "active-chats"],
              "query": [
                {
                  "key": "timeframe",
                  "value": "24h"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
