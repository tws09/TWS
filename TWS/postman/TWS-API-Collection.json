        {
          "name": "Top Chats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/analytics/top-chats?timeframe=7d&limit=10",
              "host": ["{{apiBase}}"],
              "path": ["analytics", "top-chats"],
              "query": [
                {
                  "key": "timeframe",
                  "value": "7d"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Messages by Hour",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/analytics/messages-by-hour?days=7",
              "host": ["{{apiBase}}"],
              "path": ["analytics", "messages-by-hour"],
              "query": [
                {
                  "key": "days",
                  "value": "7"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "User Activity",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/analytics/user-activity?timeframe=24h",
              "host": ["{{apiBase}}"],
              "path": ["analytics", "user-activity"],
              "query": [
                {
                  "key": "timeframe",
                  "value": "24h"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "File Uploads",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/analytics/file-uploads?timeframe=24h",
              "host": ["{{apiBase}}"],
              "path": ["analytics", "file-uploads"],
              "query": [
                {
                  "key": "timeframe",
                  "value": "24h"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "System Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/analytics/system-health",
              "host": ["{{apiBase}}"],
              "path": ["analytics", "system-health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Compliance",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/compliance/audit-logs?limit=50&page=1",
              "host": ["{{apiBase}}"],
              "path": ["compliance", "audit-logs"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Export Audit Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/compliance/audit-logs/export?startDate=2024-01-01&endDate=2024-12-31",
              "host": ["{{apiBase}}"],
              "path": ["compliance", "audit-logs", "export"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2024-01-01"
                },
                {
                  "key": "endDate",
                  "value": "2024-12-31"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Retention Policy",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/compliance/retention-policy",
              "host": ["{{apiBase}}"],
              "path": ["compliance", "retention-policy"]
            }
          },
          "response": []
        },
        {
          "name": "Update Retention Policy",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policies\": {\n    \"messages\": 365,\n    \"deletedMessages\": 30,\n    \"auditLogs\": 2555\n  },\n  \"enabled\": true\n}"
            },
            "url": {
              "raw": "{{apiBase}}/compliance/retention-policy",
              "host": ["{{apiBase}}"],
              "path": ["compliance", "retention-policy"]
            }
          },
          "response": []
        },
        {
          "name": "Get Retention Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/compliance/retention-statistics",
              "host": ["{{apiBase}}"],
              "path": ["compliance", "retention-statistics"]
            }
          },
          "response": []
        },
        {
          "name": "Generate Retention Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/compliance/retention-report",
              "host": ["{{apiBase}}"],
              "path": ["compliance", "retention-report"]
            }
          },
          "response": []
