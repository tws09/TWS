flowchart LR
    subgraph Frontend["Frontend Layer"]
        A[User Input] --> B[Form State]
        B --> C[Validation]
        C --> D[Sanitization]
        D --> E[API Service]
    end
    
    subgraph Network["Network Layer"]
        E --> F[HTTP Request]
        F --> G[Headers + Body]
        G --> H[Proxy/Server]
    end
    
    subgraph Backend["Backend Layer"]
        H --> I[Express Router]
        I --> J[Middleware Chain]
        J --> K[Controller]
        K --> L[Business Logic]
        L --> M[Database]
    end
    
    subgraph Response["Response Flow"]
        M --> N[Database Result]
        N --> O[Controller Response]
        O --> P[HTTP Response]
        P --> Q[API Service]
        Q --> R[Component Update]
        R --> S[UI Refresh]
    end
    
    Frontend --> Network
    Network --> Backend
    Backend --> Response
    Response --> Frontend
