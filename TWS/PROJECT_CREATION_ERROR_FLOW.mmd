flowchart TD
    Start[User Submits Form] --> Validate{Form Validation}
    Validate -->|Invalid| ShowErrors[Display Validation Errors]
    Validate -->|Valid| Sanitize[Sanitize Data]
    
    Sanitize --> CheckToken{Token Exists?}
    CheckToken -->|No| TokenError[Show Please log in Error]
    CheckToken -->|Yes| SendRequest[Send HTTP Request]
    
    SendRequest --> AuthCheck{Authentication}
    AuthCheck -->|401| CheckExpired{Token Expired?}
    CheckExpired -->|Yes| RefreshToken[Refresh Token]
    RefreshToken --> RetryRequest[Retry Request]
    RetryRequest --> AuthCheck
    CheckExpired -->|No| AuthError[Show Authentication Error]
    
    AuthCheck -->|200/201| TenantCheck{Tenant Access}
    TenantCheck -->|403| AccessError[Show Access Denied Error]
    TenantCheck -->|404| TenantError[Show Tenant Not Found Error]
    
    TenantCheck -->|200| OrgCheck{Organization ID Found?}
    OrgCheck -->|No| OrgError[Show Organization Context Not Available Error]
    
    OrgCheck -->|Yes| ValidateData{Data Valid?}
    ValidateData -->|No| ValidationError[Show Validation Error]
    
    ValidateData -->|Yes| CheckDuplicate{Project Exists?}
    CheckDuplicate -->|Yes| DuplicateError[Show Project Already Exists Error]
    
    CheckDuplicate -->|No| CreateDB[Create in Database]
    CreateDB --> DBSuccess{Save Success?}
    DBSuccess -->|No| DBError[Show Database Error Error]
    DBSuccess -->|Yes| Success[Show Success Message Close Modal Refresh List]
    
    ShowErrors --> End[End]
    TokenError --> End
    AuthError --> End
    AccessError --> End
    TenantError --> End
    OrgError --> End
    ValidationError --> End
    DuplicateError --> End
    DBError --> End
    Success --> End
