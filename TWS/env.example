# ===========================================
# TWS (Tenant Workspace System) Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your actual values
# For deployment, add these variables in your deployment environment

# ===========================================
# REQUIRED VARIABLES (Must be set for production)
# ===========================================

# MongoDB Connection String
# Get this from MongoDB Atlas or your MongoDB instance
MONGO_URI=mongodb+srv://subhan:U3SNm3nRjvtHMiN7@cluster0.rlfss7x.mongodb.net/wolfstack

# JWT Secrets (Generate secure random strings)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secure-jwt-secret-at-least-64-characters-long
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-at-least-64-characters-long

# Encryption Master Key (32 characters minimum)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=your-32-character-encryption-master-key

# ===========================================
# OPTIONAL VARIABLES (Have defaults)
# ===========================================

# Environment
NODE_ENV=production
PORT=4000

# Redis is now handled by WSL Ubuntu (localhost:6379)
# No Redis environment variables needed

# AWS Configuration (for file uploads - Document Hub, homework, etc.)
# Get credentials from AWS IAM: IAM → Users → Security credentials → Access keys
# Leave empty to disable S3 uploads (you'll get a clear error when uploading)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_REGION=us-east-1

# Firebase Configuration (for notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Email Service (SendGrid)
SENDGRID_API_KEY=


# Application URLs
BASE_URL=https://your-app.domain.com
SOCKET_CORS_ORIGIN=https://your-app.domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Feature Flags
ENCRYPTION_ENABLED=true
AUDIT_LOGGING_ENABLED=true
RBAC_ENABLED=true
COMPLIANCE_MODE=disabled
GDPR_COMPLIANCE=false
SOX_COMPLIANCE=false
HIPAA_COMPLIANCE=false
BACKUP_ENABLED=false
MONITORING_ENABLED=true
METRICS_ENABLED=true
