@startuml TWS_Use_Case_07_Common_Features
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

' =======================
' ACTOR STYLES
' =======================
skinparam actor {
    FontName "Arial"
    FontSize 10
    BorderThickness 1
}

skinparam actor<<Admin>> {
    BackgroundColor #E1F5FE
    BorderColor #01579B
}

skinparam actor<<Internal>> {
    BackgroundColor #E0F2F1
    BorderColor #00695C
}

skinparam actor<<External>> {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

' =======================
' USE CASE STYLES
' =======================

skinparam usecase<<Core>> {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    BorderThickness 1
}

skinparam usecase<<Support>> {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    BorderThickness 1
}

skinparam usecase<<Security>> {
    BackgroundColor #FCE4EC
    BorderColor #AD1457
    BorderThickness 1
}

' =======================
' SYSTEM BOUNDARY
' =======================
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #424242
    BorderThickness 1
}

title TWS Multi-Tenant ERP Platform – Common Features Use Case Diagram

left to right direction
scale 0.70

' =======================
' ACTORS (All on Left Side)
' =======================
actor "Supra Admin" as SupraAdmin <<Admin>>
actor "Tenant Admin" as TenantAdmin <<Admin>>
actor "Manager" as Manager <<Internal>>
actor "Employee" as Employee <<Internal>>

' =======================
' SYSTEM BOUNDARY
' =======================
rectangle "TWS MULTI-TENANT ERP SYSTEM" {

    package "Common ERP Features" {
        usecase "View Dashboard\n& Analytics" as UC10 <<Support>>
        usecase "Generate & Export\nReports" as UC11 <<Support>>
        usecase "Send Messages &\nNotifications" as UC12 <<Support>>
        usecase "Manage User Profile" as UC14 <<Support>>
        usecase "View User Activity\nHistory" as UC16 <<Support>>

        usecase "Authenticate User" as UC_Auth <<Security>>
        usecase "Recover Password" as UC_Password <<Security>>
    }
}

' =======================
' ACTOR ASSOCIATIONS (Orthogonal Routing)
' All actors connect to Authenticate User
' =======================
SupraAdmin --> UC_Auth
SupraAdmin --> UC10
SupraAdmin --> UC11
SupraAdmin --> UC16

TenantAdmin --> UC_Auth
TenantAdmin --> UC10
TenantAdmin --> UC11
TenantAdmin --> UC12
TenantAdmin --> UC14
TenantAdmin --> UC16

Manager --> UC_Auth
Manager --> UC10
Manager --> UC11
Manager --> UC12
Manager --> UC14

Employee --> UC_Auth
Employee --> UC10
Employee --> UC12
Employee --> UC14
Employee --> UC_Password

' =======================
' USE CASE RELATIONSHIPS
' All use cases <<include>> Authenticate User
' =======================
UC10 ..> UC_Auth : <<include>>
UC11 ..> UC_Auth : <<include>>
UC12 ..> UC_Auth : <<include>>
UC14 ..> UC_Auth : <<include>>
UC16 ..> UC_Auth : <<include>>

UC_Password ..> UC_Auth : <<extend>>

' =======================
' NOTES
' =======================
note right of UC10
  Real-time metrics
  KPI dashboards
  Customizable widgets
  Multi-tenant analytics
end note

note right of UC11
  Scheduled reports
  Export (PDF, Excel, CSV)
  Industry-specific reports
  Custom report builder
end note

note right of UC12
  Real-time messaging
  Email notifications
  Push notifications
  Notification templates
end note

note right of UC14
  Profile management
  Preferences
  Security settings
  Activity tracking
end note

@enduml
