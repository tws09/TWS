# TWS Backend – use when deploying from repo root (no Root Directory set).
# In Railway: set Builder to "DOCKERFILE" and Dockerfile path to "Dockerfile.backend".
# Build context must be repo root so COPY paths below resolve.

FROM node:18-alpine

WORKDIR /app

COPY TWS/backend/package*.json ./
RUN npm install --production

COPY TWS/backend/ .

EXPOSE 5000

CMD ["npm", "start"]
