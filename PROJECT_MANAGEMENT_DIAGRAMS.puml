@startuml Activity Flow Network

package "Project Management Activities" {
  
  rectangle "Project Creation" as PC
  rectangle "Resource Allocation" as RA
  rectangle "Task Creation" as TC
  rectangle "Time Tracking" as TT
  rectangle "Sprint Planning" as SP
  rectangle "Milestone Creation" as MC
  rectangle "Status Updates" as SU
  rectangle "Budget Calculation" as BC
  rectangle "Utilization Tracking" as UT
  rectangle "Velocity Tracking" as VT
  rectangle "Progress Calculation" as PR
  rectangle "Milestone Tracking" as MT
  rectangle "Client Portal Setup" as CPS
  rectangle "Client Collaboration" as CC
  
  PC --> RA
  PC --> TC
  PC --> MC
  PC --> CPS
  
  RA --> UT
  TC --> TT
  TC --> SP
  TC --> SU
  
  TT --> BC
  SP --> VT
  SU --> PR
  MC --> MT
  CPS --> CC
  
  note right of PC : Initial project setup\nenables all other activities
  
  note right of TT : Time entries feed\ninto budget and\nutilization calculations
  
  note right of SP : Sprint planning\nrequires backlog\ntasks and team capacity
}

@enduml

' ============================================

@startuml Complete Project Lifecycle

start

:Project Request Received;
:Create Project\n(Status: Planning);
:Allocate Team & Budget;
:Kick Off Project\n(Status: Active);

partition "Execution Phase" {
  :Create Tasks & Milestones;
  :Plan Sprints (if Scrum);
  
  repeat
    :Work on Tasks;
    :Track Time;
    :Update Task Status;
    :Update Progress;
  repeat while (Tasks Incomplete?) is (yes)
  ->no;
  
  :Complete Deliverables;
}

:Client Review & Approval;

if (Approved?) then (yes)
  :Mark Project Complete\n(Status: Completed);
  :Generate Final Report;
  :Archive Project;
  stop
else (no)
  if (Budget Exceeded?) then (yes)
    :Put On Hold\n(Status: On Hold);
    :Review & Adjust;
    :Resume Project;
  else (no)
    :Request Changes;
    :Continue Development;
  endif
endif

if (Cancelled?) then (yes)
  :Cancel Project\n(Status: Cancelled);
  stop
endif

@enduml

' ============================================

@startuml Resource Allocation Flow

start

:View Available Resources;
:Check Resource Capacity;
:Select Resource;
:View Current Allocations;

if (Capacity Available?) then (yes)
  :Select Target Project;
  :Set Allocation Percentage;
  :Set Start/End Dates;
  :Set Hourly Rate;
  
  :Calculate Total Allocation;
  
  if (Total <= 100%?) then (yes)
    :Allocate Resource;
    :Update Resource Workload;
    :Update Project Team;
    :Notify Resource;
    :Update Utilization Metrics;
    stop
  else (no)
    :Warning: Over-allocation;
    :Request Confirmation;
    
    if (Confirm?) then (yes)
      :Allocate with Warning;
      :Update Metrics;
      stop
    else (no)
      :Cancel Allocation;
      stop
    endif
  endif
else (no)
  :Resource at Capacity;
  :Suggest Alternative Resources;
  stop
endif

@enduml
