@startuml TWS_Use_Case_Diagram_Main
!theme plain
skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #FFF3E0
    BorderColor #E65100
    BorderThickness 2
    FontSize 10
}
skinparam actor {
    BackgroundColor #E1F5FF
    BorderColor #01579B
    BorderThickness 2
    FontSize 11
}
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #333333
    BorderThickness 2
}
skinparam package {
    BackgroundColor #FFFFFF
    BorderColor #CCCCCC
    BorderThickness 1
}

title TWS Multi-Tenant ERP Platform - Use Case Diagram

' Left Side Actors
actor "Supra Admin" as SupraAdmin
actor "Tenant Admin" as TenantAdmin
actor "Manager" as Manager
actor "Employee" as Employee

' Right Side Actors
actor "Principal" as Principal
actor "Teacher" as Teacher
actor "Student" as Student
actor "Doctor" as Doctor
actor "Patient" as Patient
actor "Project Manager" as ProjectMgr
actor "Developer" as Developer
actor "Pre-Tenant User" as PreTenantUser

' System Boundary - Center
rectangle "TWS MULTI-TENANT ERP SYSTEM" {
    
    ' Authentication Use Cases
    usecase "UC-01:\nUser Login /\nAuthentication" as UC01
    usecase "UC-02:\nSelf-Serve Tenant\nSignup & Provisioning" as UC02
    usecase "UC-15:\nPassword Recovery" as UC15
    
    ' Administration Use Cases
    usecase "UC-03:\nTenant Management" as UC03
    usecase "UC-04:\nUser Management\n(Tenant Level)" as UC04
    usecase "UC-05:\nRole & Permission\nManagement" as UC05
    usecase "UC-06:\nMaster ERP Template\nManagement" as UC06
    usecase "UC-13:\nSubscription &\nBilling Management" as UC13
    usecase "UC-16:\nUser Activity History" as UC16
    
    ' Industry Module Use Cases
    usecase "UC-07:\nEducation ERP\nModule Management" as UC07
    usecase "UC-08:\nHealthcare ERP\nModule Management" as UC08
    usecase "UC-09:\nSoftware House ERP\nModule Management" as UC09
    
    ' Common Feature Use Cases
    usecase "UC-10:\nDashboard &\nAnalytics" as UC10
    usecase "UC-11:\nReport Generation\n& Export" as UC11
    usecase "UC-12:\nMessaging &\nNotifications" as UC12
    usecase "UC-14:\nUser Profile\nManagement" as UC14
}

' === SUPRA ADMIN RELATIONSHIPS ===
SupraAdmin --> UC01
SupraAdmin --> UC03
SupraAdmin --> UC06
SupraAdmin --> UC10
SupraAdmin --> UC11
SupraAdmin --> UC13
SupraAdmin --> UC16

' === TENANT ADMIN RELATIONSHIPS ===
TenantAdmin --> UC01
TenantAdmin --> UC02
TenantAdmin --> UC04
TenantAdmin --> UC05
TenantAdmin --> UC07
TenantAdmin --> UC08
TenantAdmin --> UC09
TenantAdmin --> UC10
TenantAdmin --> UC11
TenantAdmin --> UC12
TenantAdmin --> UC13
TenantAdmin --> UC14
TenantAdmin --> UC16

' === MANAGER RELATIONSHIPS ===
Manager --> UC01
Manager --> UC04
Manager --> UC10
Manager --> UC11
Manager --> UC12
Manager --> UC14

' === EMPLOYEE RELATIONSHIPS ===
Employee --> UC01
Employee --> UC10
Employee --> UC12
Employee --> UC14
Employee --> UC15

' === EDUCATION ACTORS RELATIONSHIPS ===
Principal --> UC01
Principal --> UC07
Principal --> UC10
Principal --> UC11
Principal --> UC12
Principal --> UC14

Teacher --> UC01
Teacher --> UC07
Teacher --> UC10
Teacher --> UC11
Teacher --> UC12
Teacher --> UC14

Student --> UC01
Student --> UC07
Student --> UC10
Student --> UC12
Student --> UC14
Student --> UC15

' === HEALTHCARE ACTORS RELATIONSHIPS ===
Doctor --> UC01
Doctor --> UC08
Doctor --> UC10
Doctor --> UC11
Doctor --> UC12
Doctor --> UC14

Patient --> UC01
Patient --> UC08
Patient --> UC10
Patient --> UC12
Patient --> UC14
Patient --> UC15

' === SOFTWARE HOUSE ACTORS RELATIONSHIPS ===
ProjectMgr --> UC01
ProjectMgr --> UC09
ProjectMgr --> UC10
ProjectMgr --> UC11
ProjectMgr --> UC12
ProjectMgr --> UC14

Developer --> UC01
Developer --> UC09
Developer --> UC10
Developer --> UC12
Developer --> UC14

' === PRE-TENANT USER RELATIONSHIPS ===
PreTenantUser --> UC01
PreTenantUser --> UC02

' === USE CASE RELATIONSHIPS ===
' Include Relationships
UC01 ..> UC10 : <<include>>
UC02 ..> UC06 : <<include>>
UC04 ..> UC05 : <<include>>
UC14 ..> UC16 : <<include>>

' Extend Relationships
UC02 ..> UC04 : <<extend>>
UC15 ..> UC01 : <<extend>>
UC07 ..> UC11 : <<extend>>
UC08 ..> UC11 : <<extend>>
UC09 ..> UC11 : <<extend>>

note right of UC01
  All users must authenticate
  before accessing system
end note

note right of UC02
  Self-serve signup creates
  tenant and organization
end note

note right of UC06
  Templates auto-applied
  during tenant creation
end note

@enduml

