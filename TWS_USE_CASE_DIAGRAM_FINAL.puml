@startuml TWS_Use_Case_Diagram_Final
!theme plain
skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #FFF3E0
    BorderColor #E65100
    BorderThickness 2
    FontSize 9
}
skinparam actor {
    BackgroundColor #E1F5FF
    BorderColor #01579B
    BorderThickness 2
    FontSize 10
}
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #333333
    BorderThickness 2
}

title TWS Multi-Tenant ERP Platform - Use Case Diagram\n(A4 Landscape - Optimized for Printing)

' ============================================
' ACTORS - LEFT SIDE
' ============================================
actor "Supra Admin" as SA
actor "Tenant Admin" as TA
actor "Manager" as M
actor "Employee" as E

' ============================================
' ACTORS - RIGHT SIDE
' ============================================
actor "Principal" as P
actor "Teacher" as T
actor "Student" as S
actor "Doctor" as D
actor "Patient" as PT
actor "Project Manager" as PM
actor "Developer" as Dev
actor "Pre-Tenant User" as PreU

' ============================================
' SYSTEM BOUNDARY
' ============================================
rectangle "TWS MULTI-TENANT ERP SYSTEM" {
    
    ' Authentication & Access
    usecase "UC-01:\nLogin" as UC01
    usecase "UC-02:\nTenant Signup" as UC02
    usecase "UC-15:\nPassword Reset" as UC15
    
    ' Administration
    usecase "UC-03:\nTenant Mgmt" as UC03
    usecase "UC-04:\nUser Mgmt" as UC04
    usecase "UC-05:\nRole Mgmt" as UC05
    usecase "UC-06:\nTemplate Mgmt" as UC06
    usecase "UC-13:\nSubscription" as UC13
    usecase "UC-16:\nActivity History" as UC16
    
    ' Industry Modules
    usecase "UC-07:\nEducation ERP" as UC07
    usecase "UC-08:\nHealthcare ERP" as UC08
    usecase "UC-09:\nSoftware House ERP" as UC09
    
    ' Common Features
    usecase "UC-10:\nDashboard" as UC10
    usecase "UC-11:\nReports" as UC11
    usecase "UC-12:\nMessaging" as UC12
    usecase "UC-14:\nProfile" as UC14
}

' ============================================
' ACTOR TO USE CASE RELATIONSHIPS
' ============================================

' Supra Admin
SA --> UC01
SA --> UC03
SA --> UC06
SA --> UC10
SA --> UC11
SA --> UC13
SA --> UC16

' Tenant Admin
TA --> UC01
TA --> UC02
TA --> UC04
TA --> UC05
TA --> UC07
TA --> UC08
TA --> UC09
TA --> UC10
TA --> UC11
TA --> UC12
TA --> UC13
TA --> UC14
TA --> UC16

' Manager
M --> UC01
M --> UC04
M --> UC10
M --> UC11
M --> UC12
M --> UC14

' Employee
E --> UC01
E --> UC10
E --> UC12
E --> UC14
E --> UC15

' Education Actors
P --> UC01
P --> UC07
P --> UC10
P --> UC11
P --> UC12
P --> UC14

T --> UC01
T --> UC07
T --> UC10
T --> UC11
T --> UC12
T --> UC14

S --> UC01
S --> UC07
S --> UC10
S --> UC12
S --> UC14
S --> UC15

' Healthcare Actors
D --> UC01
D --> UC08
D --> UC10
D --> UC11
D --> UC12
D --> UC14

PT --> UC01
PT --> UC08
PT --> UC10
PT --> UC12
PT --> UC14
PT --> UC15

' Software House Actors
PM --> UC01
PM --> UC09
PM --> UC10
PM --> UC11
PM --> UC12
PM --> UC14

Dev --> UC01
