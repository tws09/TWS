@startuml TWS_Multi_Tenant_ERP_Use_Case_Diagram
!theme plain
skinparam backgroundColor #FFFFFF
skinparam usecase {
    BackgroundColor #FFF3E0
    BorderColor #E65100
    BorderThickness 2
}
skinparam actor {
    BackgroundColor #E1F5FF
    BorderColor #01579B
    BorderThickness 2
}
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #333333
    BorderThickness 1
}

title TWS Multi-Tenant ERP Platform - Use Case Diagram

' Define Actors
actor "Supra Admin" as SupraAdmin
actor "Tenant Admin" as TenantAdmin
actor "Manager" as Manager
actor "Employee" as Employee
actor "Principal" as Principal
actor "Teacher" as Teacher
actor "Student" as Student
actor "Doctor" as Doctor
actor "Patient" as Patient
actor "Store Manager" as StoreManager
actor "Cashier" as Cashier
actor "Production Manager" as ProductionMgr
actor "Project Manager" as ProjectMgr
actor "Developer" as Developer
actor "Pre-Tenant User" as PreTenantUser

' System Boundary
rectangle "TWS MULTI-TENANT ERP SYSTEM" {
    
    ' Authentication & Access Use Cases
    usecase "UC-01: User Login\nAuthentication" as UC01
    usecase "UC-02: Self-Serve Tenant\nSignup & Provisioning" as UC02
    usecase "UC-15: Password Recovery" as UC15
    
    ' Administration Use Cases
    usecase "UC-03: Tenant\nManagement" as UC03
    usecase "UC-04: User\nManagement" as UC04
    usecase "UC-05: Role & Permission\nManagement" as UC05
    usecase "UC-06: Master ERP\nTemplate Management" as UC06
    usecase "UC-13: Subscription &\nBilling Management" as UC13
    usecase "UC-16: User Activity\nHistory" as UC16
    
    ' Industry Module Use Cases
    usecase "UC-07: Education ERP\nModule Management" as UC07
    usecase "UC-08: Healthcare ERP\nModule Management" as UC08
    usecase "UC-09: Software House ERP\nModule Management" as UC09
    
    ' Common Feature Use Cases
    usecase "UC-10: Dashboard &\nAnalytics" as UC10
    usecase "UC-11: Report Generation\n& Export" as UC11
    usecase "UC-12: Messaging &\nNotifications" as UC12
    usecase "UC-14: User Profile\nManagement" as UC14
}

' Supra Admin Relationships
SupraAdmin --> UC01 : Accesses
SupraAdmin --> UC03 : Manages
SupraAdmin --> UC06 : Manages
SupraAdmin --> UC10 : Views
SupraAdmin --> UC11 : Generates
SupraAdmin --> UC13 : Manages
SupraAdmin --> UC16 : Views

' Tenant Admin Relationships
TenantAdmin --> UC01 : Accesses
TenantAdmin --> UC02 : Initiates
TenantAdmin --> UC04 : Manages
TenantAdmin --> UC05 : Manages
TenantAdmin --> UC07 : Manages
TenantAdmin --> UC08 : Manages
TenantAdmin --> UC09 : Manages
TenantAdmin --> UC10 : Views
TenantAdmin --> UC11 : Generates
TenantAdmin --> UC12 : Uses
TenantAdmin --> UC13 : Manages
TenantAdmin --> UC14 : Manages
TenantAdmin --> UC16 : Views

' Manager Relationships
Manager --> UC01 : Accesses
Manager --> UC04 : Manages
Manager --> UC10 : Views
Manager --> UC11 : Generates
Manager --> UC12 : Uses
Manager --> UC14 : Manages

' Employee Relationships
Employee --> UC01 : Accesses
Employee --> UC10 : Views
Employee --> UC12 : Uses
Employee --> UC14 : Manages
Employee --> UC15 : Requests

' Education Actors Relationships
Principal --> UC01 : Accesses
Principal --> UC07 : Manages
Principal --> UC10 : Views
Principal --> UC11 : Generates
Principal --> UC12 : Uses
Principal --> UC14 : Manages

Teacher --> UC01 : Accesses
Teacher --> UC07 : Uses
Teacher --> UC10 : Views
Teacher --> UC11 : Generates
Teacher --> UC12 : Uses
Teacher --> UC14 : Manages

Student --> UC01 : Accesses
Student --> UC07 : Views
Student --> UC10 : Views
Student --> UC12 : Uses
Student --> UC14 : Manages
Student --> UC15 : Requests

' Healthcare Actors Relationships
Doctor --> UC01 : Accesses
Doctor --> UC08 : Manages
Doctor --> UC10 : Views
Doctor --> UC11 : Generates
Doctor --> UC12 : Uses
Doctor --> UC14 : Manages

Patient --> UC01 : Accesses
Patient --> UC08 : Views
Patient --> UC10 : Views
Patient --> UC12 : Uses
Patient --> UC14 : Manages
Patient --> UC15 : Requests

' Software House Actors Relationships
ProjectMgr --> UC01 : Accesses
ProjectMgr --> UC09 : Manages
ProjectMgr --> UC10 : Views
ProjectMgr --> UC11 : Generates
ProjectMgr --> UC12 : Uses
ProjectMgr --> UC14 : Manages

Developer --> UC01 : Accesses
Developer --> UC09 : Uses
Developer --> UC10 : Views
Developer --> UC12 : Uses
Developer --> UC14 : Manages

' Retail Actors Relationships
StoreManager --> UC01 : Accesses
StoreManager --> UC09 : Manages
StoreManager --> UC10 : Views
StoreManager --> UC11 : Generates
StoreManager --> UC12 : Uses
StoreManager --> UC14 : Manages

Cashier --> UC01 : Accesses
Cashier --> UC09 : Uses
Cashier --> UC10 : Views
Cashier --> UC12 : Uses
Cashier --> UC14 : Manages

' Manufacturing Actors Relationships
ProductionMgr --> UC01 : Accesses
ProductionMgr --> UC09 : Manages
ProductionMgr --> UC10 : Views
ProductionMgr --> UC11 : Generates
ProductionMgr --> UC12 : Uses
ProductionMgr --> UC14 : Manages

' Pre-Tenant User Relationships
PreTenantUser --> UC01 : Accesses
PreTenantUser --> UC02 : Initiates

' Use Case Relationships (Include/Extend)
UC01 ..> UC10 : <<include>>
UC02 ..> UC04 : <<extend>>
UC02 ..> UC06 : <<include>>
UC04 ..> UC05 : <<include>>
UC07 ..> UC11 : <<extend>>
UC08 ..> UC11 : <<extend>>
UC09 ..> UC11 : <<extend>>
UC14 ..> UC16 : <<include>>
UC15 ..> UC01 : <<extend>>

@enduml

