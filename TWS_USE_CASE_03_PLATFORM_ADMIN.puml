@startuml TWS_Use_Case_03_Platform_Admin
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

' =======================
' ACTOR STYLES
' =======================
skinparam actor {
    FontName "Arial"
    FontSize 10
    BorderThickness 1
}

skinparam actor<<Admin>> {
    BackgroundColor #E1F5FE
    BorderColor #01579B
}

skinparam actor<<Internal>> {
    BackgroundColor #E0F2F1
    BorderColor #00695C
}

skinparam actor<<External>> {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

' =======================
' USE CASE STYLES
' =======================

skinparam usecase<<Core>> {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    BorderThickness 1
}

skinparam usecase<<Support>> {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    BorderThickness 1
}

skinparam usecase<<Security>> {
    BackgroundColor #FCE4EC
    BorderColor #AD1457
    BorderThickness 1
}

' =======================
' SYSTEM BOUNDARY
' =======================
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #424242
    BorderThickness 1
}

title TWS Multi-Tenant ERP Platform – Platform Administration Use Case Diagram

left to right direction
scale 0.70

' =======================
' ACTORS (All on Left Side)
' =======================
actor "Platform Admin\n(Supra Admin)" as PlatformAdmin <<Admin>>
actor "Tenant Admin" as TenantAdmin <<Admin>>

' =======================
' SYSTEM BOUNDARY
' =======================
rectangle "TWS MULTI-TENANT ERP SYSTEM" {

    package "Platform Administration Module" {
        usecase "Manage Tenants" as UC03 <<Core>>
        usecase "Manage Master\nERP Templates" as UC06 <<Core>>
        usecase "Manage Users" as UC04 <<Core>>
        usecase "Manage Roles\n& Permissions" as UC05 <<Core>>
        usecase "Manage Subscriptions\n& Billing" as UC13 <<Core>>
        usecase "View User Activity\nHistory" as UC16 <<Core>>
    }

    package "Common ERP Features" {
        usecase "View Dashboard\n& Analytics" as UC10 <<Support>>
        usecase "Generate & Export\nReports" as UC11 <<Support>>
        usecase "Send Messages &\nNotifications" as UC_Comm <<Support>>
        usecase "Manage User Profile" as UC_Profile <<Support>>

        usecase "Authenticate User" as UC_Auth <<Security>>
        usecase "Recover Password" as UC_Password <<Security>>
    }
}

' =======================
' ACTOR ASSOCIATIONS (Orthogonal Routing)
' =======================
PlatformAdmin --> UC_Auth
PlatformAdmin --> UC03
PlatformAdmin --> UC06
PlatformAdmin --> UC13
PlatformAdmin --> UC16
PlatformAdmin --> UC10
PlatformAdmin --> UC11
PlatformAdmin --> UC_Profile
PlatformAdmin --> UC_Comm

TenantAdmin --> UC_Auth
TenantAdmin --> UC04
TenantAdmin --> UC05
TenantAdmin --> UC13
TenantAdmin --> UC16
TenantAdmin --> UC10
TenantAdmin --> UC11
TenantAdmin --> UC_Profile
TenantAdmin --> UC_Comm

' =======================
' USE CASE RELATIONSHIPS
' All use cases <<include>> Authenticate User
' =======================
UC03 ..> UC_Auth : <<include>>
UC06 ..> UC_Auth : <<include>>
UC04 ..> UC_Auth : <<include>>
UC05 ..> UC_Auth : <<include>>
UC13 ..> UC_Auth : <<include>>
UC16 ..> UC_Auth : <<include>>

UC10 ..> UC_Auth : <<include>>
UC11 ..> UC_Auth : <<include>>
UC_Comm ..> UC_Auth : <<include>>
UC_Profile ..> UC_Auth : <<include>>

UC_Password ..> UC_Auth : <<extend>>

' =======================
' NOTES
' =======================
note right of UC03
  Applies across all tenants\nPlatform-wide authority only
end note

note right of UC04
  Restricted to\nsingle tenant scope
end note

@enduml
