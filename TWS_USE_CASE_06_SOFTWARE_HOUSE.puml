@startuml TWS_Use_Case_06_Software_House
!theme plain
skinparam backgroundColor #FFFFFF
skinparam linetype ortho

' =======================
' ACTOR STYLES
' =======================
skinparam actor {
    FontName "Arial"
    FontSize 10
    BorderThickness 1
}

skinparam actor<<Admin>> {
    BackgroundColor #E1F5FE
    BorderColor #01579B
}

skinparam actor<<Internal>> {
    BackgroundColor #E0F2F1
    BorderColor #00695C
}

skinparam actor<<External>> {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

' =======================
' USE CASE STYLES
' =======================

skinparam usecase<<Core>> {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    BorderThickness 1
}

skinparam usecase<<Support>> {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    BorderThickness 1
}

skinparam usecase<<Security>> {
    BackgroundColor #FCE4EC
    BorderColor #AD1457
    BorderThickness 1
}

' =======================
' SYSTEM BOUNDARY
' =======================
skinparam rectangle {
    BackgroundColor #F5F5F5
    BorderColor #424242
    BorderThickness 1
}

title TWS Multi-Tenant ERP Platform – Software House Module Use Case Diagram

left to right direction
scale 0.70

' =======================
' ACTORS (LEFT & RIGHT)
' =======================
actor "Tenant Admin" as TenantAdmin <<Admin>>
actor "Project Manager" as ProjectMgr <<Internal>>
actor "Developer" as Developer <<Internal>>
actor "Client" as Client <<External>>

' =======================
' SYSTEM
' =======================
rectangle "TWS MULTI-TENANT ERP SYSTEM" {

    package "Software House Module" {
        usecase "Create & Configure\nProjects" as UC_ProjectSetup <<Core>>
        usecase "Plan & Manage\nProject Execution" as UC_ProjectManage <<Core>>
        usecase "Manage Tasks\n& Sprints" as UC_Task <<Core>>
        usecase "Track Time\n& Work Logs" as UC_Time <<Core>>
        usecase "View Project\nProgress" as UC_ViewProgress <<Core>>
        usecase "Approve\nMilestones" as UC_Approve <<Core>>
    }

    package "Common ERP Features" {
        usecase "View Dashboard\n& Analytics" as UC_Dashboard <<Support>>
        usecase "Generate & Export\nReports" as UC_Report <<Support>>
        usecase "Send Messages &\nNotifications" as UC_Comm <<Support>>
        usecase "Manage User Profile" as UC_Profile <<Support>>

        usecase "Authenticate User" as UC_Auth <<Security>>
        usecase "Recover Password" as UC_Password <<Security>>
    }
}

' =======================
' ACTOR ASSOCIATIONS
' =======================
TenantAdmin --> UC_Auth
TenantAdmin --> UC_ProjectSetup
TenantAdmin --> UC_ProjectManage
TenantAdmin --> UC_Dashboard
TenantAdmin --> UC_Report
TenantAdmin --> UC_Profile

ProjectMgr --> UC_Auth
ProjectMgr --> UC_ProjectManage
ProjectMgr --> UC_Task
ProjectMgr --> UC_Time
ProjectMgr --> UC_Dashboard
ProjectMgr --> UC_Report
ProjectMgr --> UC_Comm
ProjectMgr --> UC_Profile

Developer --> UC_Auth
Developer --> UC_Task
Developer --> UC_Time
Developer --> UC_Comm
Developer --> UC_Profile

Client --> UC_Auth
Client --> UC_ViewProgress
Client --> UC_Approve
Client --> UC_Comm
Client --> UC_Profile
Client --> UC_Password

' =======================
' USE CASE RELATIONSHIPS
' All use cases <<include>> Authenticate User
' =======================
UC_ProjectSetup ..> UC_Auth : <<include>>
UC_ProjectManage ..> UC_Auth : <<include>>
UC_Task ..> UC_Auth : <<include>>
UC_Time ..> UC_Auth : <<include>>
UC_ViewProgress ..> UC_Auth : <<include>>
UC_Approve ..> UC_Auth : <<include>>

UC_Dashboard ..> UC_Auth : <<include>>
UC_Report ..> UC_Auth : <<include>>
UC_Comm ..> UC_Auth : <<include>>
UC_Profile ..> UC_Auth : <<include>>

UC_Password ..> UC_Auth : <<extend>>

@enduml
